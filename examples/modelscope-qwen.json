{
  "providers": [
    {
      "name": "modelscope-qwen-397b",
      "base_url": "https://api-inference.modelscope.cn/v1",
      "model": "Qwen/Qwen3.5-397B-A17B",
      "api_key_env": "MODELSCOPE_API_KEY",
      "timeout_seconds": 120
    }
  ],
  "run": {
    "repeats": 2,
    "output": "artifacts/modelscope-qwen-report.json",
    "temperature": 0,
    "capture_headers": true
  },
  "suite": {
    "cases": [
      {
        "name": "exact_json",
        "enabled": true
      },
      {
        "name": "exact_line",
        "enabled": true
      },
      {
        "name": "logic_filter",
        "enabled": true
      },
      {
        "name": "chinese_compact",
        "enabled": true
      },
      {
        "name": "nested_json_schema",
        "enabled": true
      },
      {
        "name": "response_format_json_schema",
        "enabled": false
      },
      {
        "name": "go_snippet_output",
        "enabled": true
      },
      {
        "name": "tool_call_echo",
        "enabled": false
      },
      {
        "name": "long_context_needle_small",
        "enabled": true,
        "params": {
          "approx_tokens": 4000
        }
      },
      {
        "name": "long_context_needle_medium",
        "enabled": false,
        "params": {
          "approx_tokens": 12000
        }
      }
    ]
  }
}
